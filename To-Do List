import tkinter as tk
from tkinter import messagebox

def add_task():
    task = task_entry.get()
    if task:
        task_listbox.insert(tk.END, "[ ] " + task)
        task_entry.delete(0, tk.END)
    else:
        messagebox.showwarning("Warning", "Please enter a task!")

def update_task():
    selected = task_listbox.curselection()

    if selected:
        index = selected[0]
        new_task = task_entry.get()

        if new_task:
            task_listbox.delete(index)
            task_listbox.insert(index, "[ ] " + new_task)
            task_entry.delete(0, tk.END)
        else:
            messagebox.showwarning("Warning", "Enter updated task!")
    else:
        messagebox.showwarning("Warning", "Select a task first!")

def delete_task():
    selected = task_listbox.curselection()

    if selected:
        task_listbox.delete(selected[0])
    else:
        messagebox.showwarning("Warning", "Select a task first!")

def mark_complete():
    selected = task_listbox.curselection()

    if selected:
        index = selected[0]
        task = task_listbox.get(index)

        if "[✓]" not in task:
            task = task.replace("[ ]", "[✓]")
            task_listbox.delete(index)
            task_listbox.insert(index, task)
    else:
        messagebox.showwarning("Warning", "Select a task first!")

# Main Window
root = tk.Tk()
root.title("To-Do List")
root.geometry("500x400")

# Heading
title = tk.Label(root, text="TO-DO LIST", font=("Arial", 18, "bold"))
title.pack(pady=10)

# Entry Box
task_entry = tk.Entry(root, width=40, font=("Arial", 12))
task_entry.pack(pady=10)

# Buttons
add_btn = tk.Button(root, text="Add Task", command=add_task)
add_btn.pack(pady=5)

update_btn = tk.Button(root, text="Update Task", command=update_task)
update_btn.pack(pady=5)

delete_btn = tk.Button(root, text="Delete Task", command=delete_task)
delete_btn.pack(pady=5)

complete_btn = tk.Button(root, text="Mark Complete", command=mark_complete)
complete_btn.pack(pady=5)

# Listbox
task_listbox = tk.Listbox(root, width=50, height=10, font=("Arial", 12))
task_listbox.pack(pady=15)

root.mainloop()
